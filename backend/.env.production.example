NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_DB_HOST:6543/postgres?sslmode=require
SPORTSDATAIO_API_KEY=YOUR_SPORTSDATAIO_KEY
SPORTSDATAAPI_KEY=YOUR_SPORTSDATAIO_KEY
INGEST_ENABLED=true
INGEST_INTERVAL_SECONDS=60
INGEST_INCLUDE_BRACKET_AUTO=false
SPORTSDATAIO_NFL_SCHEDULES_URL_TEMPLATE=https://api.sportsdata.io/v3/nfl/scores/json/Schedules/{season}
SPORTSDATAIO_NBA_GAMES_BY_DATE_URL_TEMPLATE=https://api.sportsdata.io/v3/nba/scores/json/GamesByDate/{date}
SPORTSDATAIO_CBB_GAMES_BY_DATE_URL_TEMPLATE=https://api.sportsdata.io/v3/cbb/scores/json/GamesByDate/{date}
SPORTSDATAIO_NHL_GAMES_BY_DATE_URL_TEMPLATE=https://api.sportsdata.io/v3/nhl/scores/json/GamesByDate/{date}
SPORTSDATAIO_SOCCER_GAMES_BY_DATE_URL_TEMPLATE=https://api.sportsdata.io/v4/soccer/scores/json/GamesByDate/{date}
